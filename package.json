{
  "name": "zenshin-contents",
  "version": "0.0.1",
  "private": true,
  "description": "ZENSHIN のスライド・CG などを公開するコンテンツハブ（Marp + GitHub Pages）",
  "type": "module",
  "scripts": {
    "dev": "bunx marp --server --theme-set themes slides",
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun run build && bun run check",
    "check": "bun scripts/check-overflow.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZENSHIN-Inc/zenshin-contents.git"
  },
  "homepage": "https://contents.zenshin-inc.co.jp/",
  "devDependencies": {
    "@marp-team/marp-cli": "^4.4.1",
    "@types/bun": "^1.3.14",
    "typescript": "npm:typescript@^7.0.1-rc"
  },
  "engines": {
    "node": ">=26 <27"
  },
  "packageManager": "bun@1.3.14"
}
