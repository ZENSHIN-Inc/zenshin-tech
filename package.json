{
  "name": "zenshin-contents",
  "version": "0.0.1",
  "private": true,
  "description": "ZENSHIN のスライド・CG などを公開するコンテンツハブ（Marp + GitHub Pages）",
  "type": "module",
  "scripts": {
    "dev": "bunx marp --server --theme-set themes slides",
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun run sync:agent-docs:check && bun run build && bun run check",
    "check": "bun scripts/check-overflow.ts",
    "sync:agent-docs": "bun scripts/sync-agent-docs.ts",
    "sync:agent-docs:check": "bun scripts/sync-agent-docs.ts --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZENSHIN-Inc/zenshin-contents.git"
  },
  "homepage": "https://contents.zenshin-inc.co.jp/",
  "devDependencies": {
    "@marp-team/marp-cli": "^4.4.1",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=26 <27"
  },
  "packageManager": "bun@1.3.14"
}
