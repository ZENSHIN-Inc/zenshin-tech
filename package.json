{
  "name": "zenshin-tech",
  "version": "0.0.1",
  "private": true,
  "description": "株式会社ZENSHIN の技術ブログ「ZENSHIN 技術ブログ」（Astro + Marp + Cloudflare Pages）",
  "type": "module",
  "scripts": {
    "dev": "bun run slides && astro dev",
    "dev:marp": "bunx marp --server --theme-set themes slides",
    "slides": "bun scripts/build-slides.ts",
    "build": "bun run slides && astro build && bunx pagefind --site dist",
    "preview": "astro preview",
    "typecheck": "bun run cf-typegen && astro check && tsc --noEmit -p functions/tsconfig.json",
    "ci": "bun run sync:agent-docs:check && bun run build && bun run typecheck && bun run check",
    "check": "bun scripts/check-overflow.ts",
    "link-cards:refresh": "rm -rf public/link-cards .astro node_modules/.astro && bun run build",
    "sync:agent-docs": "bun scripts/sync-agent-docs.ts",
    "sync:agent-docs:check": "bun scripts/sync-agent-docs.ts --check",
    "cf-typegen": "wrangler types"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZENSHIN-Inc/zenshin-tech.git"
  },
  "homepage": "https://tech.zenshin-inc.co.jp/",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.90",
    "@marp-team/marp-cli": "^4.4.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "^1.3.14",
    "hast": "^1.0.0",
    "pagefind": "^1.5.2",
    "satori": "^0.28.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "typescript-7": "npm:typescript@^7.0.2",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=26 <27"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.4",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "^7.1.0",
    "astro-icon": "^1.1.5",
    "satteri": "^0.9.5",
    "zod": "^4.4.3"
  }
}
