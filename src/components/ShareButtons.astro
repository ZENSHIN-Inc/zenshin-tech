---
/**
 * シェアボタン — X（旧 Twitter）とリンクコピー
 *
 * X は OGP 画像（twitter:card=summary_large_image）を自動展開するため、
 * URL を intent?url= に渡すだけで大きな画像カードが表示される。
 * テキストは Zenn 風に「タイトル｜著者名」形式で組み立てる。
 */
import { Icon } from "astro-icon/components";

interface Props {
  url: string;
  title: string;
  /** intent?hashtags= に渡すハッシュタグ（# なし、カンマ区切り） */
  hashtags?: string;
  /** 配置方向。vertical は左サイド sticky 用のアイコン縦並び（ラベル非表示） */
  orientation?: "horizontal" | "vertical";
  class?: string;
}

const {
  url,
  title,
  hashtags = "ZENSHIN技術ブログ",
  orientation = "horizontal",
  class: className = "",
} = Astro.props;

const shareText = title;
const params = new URLSearchParams({
  text: shareText,
  url,
  hashtags,
});
const xShareUrl = `https://twitter.com/intent/tweet?${params.toString()}`;
---

<div
  class:list={[
    "flex",
    orientation === "horizontal"
      ? "items-center gap-2"
      : "flex-col items-center gap-3",
    className,
  ]}
  data-share-root
>
  {orientation === "horizontal" && (
    <span class="mr-1 text-xs font-medium text-muted-light">記事をシェア</span>
  )}
  <a
    href={xShareUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="X でシェア"
    class="group inline-flex h-9 w-9 items-center justify-center rounded-full border border-border bg-white text-muted transition-all hover:border-primary hover:text-primary active:scale-95 active:opacity-80"
  >
    <Icon name="simple-icons:x" class="h-3.5 w-3.5" />
  </a>
  <button
    type="button"
    data-copy-url={url}
    aria-label="記事のURLをコピー"
    class="group relative inline-flex h-9 w-9 items-center justify-center rounded-full border border-border bg-white text-muted transition-all hover:border-accent hover:text-accent active:scale-95 active:opacity-80 data-[copied=true]:border-success data-[copied=true]:text-success"
  >
    <Icon name="heroicons:link-20-solid" class="h-4 w-4 data-[copied=true]:hidden" data-copy-icon />
    <Icon name="heroicons:check-20-solid" class="hidden h-4 w-4 data-[copied=true]:block" data-check-icon />
  </button>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-copy-url]").forEach((btn) => {
    let resetTimer: ReturnType<typeof setTimeout> | null = null;

    btn.addEventListener("click", async () => {
      const url = btn.dataset.copyUrl;
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);
      } catch {
        return;
      }

      btn.dataset.copied = "true";
      const copyIcon = btn.querySelector<SVGElement>("[data-copy-icon]");
      const checkIcon = btn.querySelector<SVGElement>("[data-check-icon]");
      if (copyIcon) copyIcon.style.display = "none";
      if (checkIcon) checkIcon.style.display = "block";
      btn.classList.add("border-success", "text-success");
      btn.setAttribute("aria-label", "コピーしました");

      if (resetTimer) clearTimeout(resetTimer);
      resetTimer = setTimeout(() => {
        delete btn.dataset.copied;
        if (copyIcon) copyIcon.style.display = "";
        if (checkIcon) checkIcon.style.display = "";
        btn.classList.remove("border-success", "text-success");
        btn.setAttribute("aria-label", "記事のURLをコピー");
      }, 1800);
    });
  });
</script>
