---
/**
 * 関連スライドブロック（ブログ記事ページ用）
 *
 * 現在の記事と同じタグを持つスライドを、タグの一致数が多い順・次に新しい順で
 * 並べて上位 N 件表示する。RelatedPosts と違い、タグ一致 0 件でも新しい順で
 * 埋める（スライドは本数が少なく回遊導線として常に見せたいため）。
 * スライドが 1 本もない場合のみ何もレンダリングしない。
 */
import { getCollection } from "astro:content";
import ArticleCard from "./ArticleCard.astro";

interface Props {
  tags: string[];
  limit?: number;
  class?: string;
  /** スライドビューワーページから使う場合に、表示中のデッキを除外する */
  currentId?: string;
}

const { tags, limit = 3, class: className = "", currentId } = Astro.props;

const allSlides = await getCollection("slides");

const related = allSlides
  .filter((slide) => slide.id !== currentId)
  .map((slide) => ({
    slide,
    matchCount: slide.data.tags.filter((t) => tags.includes(t)).length,
  }))
  .sort((a, b) => {
    if (a.matchCount !== b.matchCount) return b.matchCount - a.matchCount;
    return b.slide.data.date.getTime() - a.slide.data.date.getTime();
  })
  .slice(0, limit)
  .map((x) => x.slide);
---

{related.length > 0 && (
  <section class:list={[className]} aria-labelledby="related-slides-heading">
    <h2
      id="related-slides-heading"
      class="mb-5 text-base font-bold text-primary md:text-lg"
    >
      関連スライド
    </h2>
    <ul class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((slide, i) => (
        <ArticleCard
          href={slide.data.urls.page}
          ogImageSrc={slide.data.urls.ogImage}
          title={slide.data.title}
          tags={slide.data.tags}
          date={slide.data.date}
          pdfHref={slide.data.urls.pdf}
          linkable
          delay={String(Math.min(i + 1, 3))}
          viewCountSlug={slide.id}
        />
      ))}
    </ul>
  </section>
)}
