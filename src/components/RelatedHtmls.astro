---
/**
 * 関連 HTML ページブロック（記事・スライド・HTML ビューワーページ用）
 *
 * 現在のコンテンツと同じタグを持つ HTML ページを、タグの一致数が多い順・
 * 次に新しい順で並べて上位 N 件表示する。RelatedSlides と同じく、タグ一致
 * 0 件でも新しい順で埋める（本数が少なく回遊導線として常に見せたいため）。
 * HTML ページが 1 本もない場合のみ何もレンダリングしない。
 */
import ArticleCard from "./ArticleCard.astro";
import { getHtmls } from "@/lib/htmls";

interface Props {
  tags: string[];
  limit?: number;
  class?: string;
  /** HTML ビューワーページから使う場合に、表示中のページを除外する */
  currentId?: string;
}

const { tags, limit = 3, class: className = "", currentId } = Astro.props;

const allHtmls = await getHtmls();

const related = allHtmls
  .filter((page) => page.id !== currentId)
  .map((page) => ({
    page,
    matchCount: page.data.tags.filter((t) => tags.includes(t)).length,
  }))
  .sort((a, b) => {
    if (a.matchCount !== b.matchCount) return b.matchCount - a.matchCount;
    return b.page.data.date.getTime() - a.page.data.date.getTime();
  })
  .slice(0, limit)
  .map((x) => x.page);
---

{related.length > 0 && (
  <section class:list={[className]} aria-labelledby="related-htmls-heading">
    <h2
      id="related-htmls-heading"
      class="mb-5 text-base font-bold text-primary md:text-lg"
    >
      関連 HTML 資料
    </h2>
    <ul class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((page, i) => (
        <ArticleCard
          href={page.data.urls.page}
          ogImageSrc={page.data.urls.ogImage}
          title={page.data.title}
          tags={page.data.tags}
          date={page.data.date}
          linkable
          delay={String(Math.min(i + 1, 3))}
          viewCountSlug={page.id}
        />
      ))}
    </ul>
  </section>
)}
