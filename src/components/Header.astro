---
/**
 * サイトヘッダー（ZENSHIN Tech）
 *
 * zenshin-hp と地続きの意匠（ダーク地 + 白ナビ）。
 * ロックアップは「ZENSHIN ロゴ + TECH 金チップ」（ロゴは h-7 を維持し、チップは垂直センター揃え）。
 * コンテンツ種別のナビ（ブログ/スライド）は持たず、検索と会社サイトのみ。
 */
import { Icon } from "astro-icon/components";
import { ROUTES } from "@/consts/routes";
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-surface-dark">
  <div class="mx-auto max-w-6xl px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">
      <!-- ロックアップ: ロゴ + TECH 金チップ（垂直センター揃え） -->
      <a href={ROUTES.home} class="relative z-50 flex items-center gap-2.5 active:opacity-70 active:scale-95">
        <img
          src="/assets/brand/ZENSHIN-logo-white.webp"
          alt="ZENSHIN"
          width="140"
          height="32"
          class="h-7 w-auto"
          loading="eager"
          fetchpriority="high"
        />
        {/* ZENSHIN サブブランドバッジ（完全な四角・Michroma・金グラデ × 白抜き） */}
        <span
          class="rounded-none bg-[linear-gradient(135deg,#e4d4a8,#c4a97d_55%,#8c6f42)] px-[10px] py-[7px] font-[Michroma] text-[12px] font-normal uppercase leading-none tracking-[0.18em] text-white"
        >
          Tech
        </span>
      </a>

      <!-- 右側: 検索 + 会社サイト -->
      <div class="flex items-center gap-2 md:gap-5">
        <button
          id="search-open"
          class="flex h-11 w-11 items-center justify-center rounded-lg text-on-surface-dark/90 transition-colors hover:text-white active:opacity-70 active:scale-95"
          aria-label="サイト内検索"
        >
          <Icon name="heroicons:magnifying-glass-20-solid" class="h-5 w-5" aria-hidden="true" />
        </button>
        <a
          href={ROUTES.corporate}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden items-center gap-1 text-sm font-medium text-on-surface-dark/90 transition-all duration-200 hover:text-white active:opacity-70 active:scale-95 md:inline-flex"
        >
          <span>会社サイト</span>
          <Icon name="heroicons:arrow-top-right-on-square-20-solid" class="h-3.5 w-3.5 opacity-60" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>
</header>

<!-- 検索モーダル（Pagefind）。インデックスはビルド後に `pagefind --site dist` が生成する -->
<div id="search-modal" class="fixed inset-0 z-[60] hidden" role="dialog" aria-modal="true" aria-label="サイト内検索">
  <div id="search-overlay" class="absolute inset-0 bg-surface-dark/70 backdrop-blur-sm"></div>
  <div class="relative mx-auto mt-20 w-[min(640px,calc(100vw-2rem))] rounded-2xl bg-white p-5 shadow-2xl md:mt-28">
    <div id="pagefind-container" class="min-h-24"></div>
    <p class="mt-3 text-right text-xs text-muted-light">Esc で閉じる</p>
  </div>
</div>

{/* is:inline: Vite にバンドルさせない。バンドルすると動的 import が preload ヘルパーに
    変換され、インラインスクリプトでは __VITE_PRELOAD__ が未置換のまま残って実行時エラーになる */}
<script is:inline>
  const openBtn = document.getElementById("search-open");
  const modal = document.getElementById("search-modal");
  const overlay = document.getElementById("search-overlay");
  let initialized = false;

  async function initPagefind() {
    if (initialized) return;
    initialized = true;
    const container = document.getElementById("pagefind-container");
    try {
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "/pagefind/pagefind-ui.css";
      document.head.appendChild(link);
      // pagefind-ui.js は ESM export を持たず window.PagefindUI を定義するクラシックスクリプト
      // （/pagefind/ は `pagefind --site dist` が生成するビルド成果物専用モジュール）
      await import("/pagefind/pagefind-ui.js");
      const PagefindUI = window.PagefindUI;
      if (!PagefindUI) throw new Error("PagefindUI not found");
      new PagefindUI({
        element: "#pagefind-container",
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: "記事を検索",
          zero_results: "「[SEARCH_TERM]」に一致する記事はありません",
          clear_search: "クリア",
          load_more: "さらに表示",
          many_results: "[COUNT] 件の結果",
          one_result: "1 件の結果",
          searching: "検索中…",
        },
      });
    } catch {
      if (container) {
        container.innerHTML =
          '<p class="text-sm text-muted">検索インデックスがありません（`bun run build` 後の preview / 本番で有効になります）</p>';
      }
    }
  }

  function openSearch() {
    modal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    initPagefind().then(() => {
      setTimeout(() => modal?.querySelector("input")?.focus(), 80);
    });
  }

  function closeSearch() {
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  openBtn?.addEventListener("click", openSearch);
  overlay?.addEventListener("click", closeSearch);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal?.classList.contains("hidden")) closeSearch();
    // Cmd/Ctrl + K でも開ける
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openSearch();
    }
  });
</script>
