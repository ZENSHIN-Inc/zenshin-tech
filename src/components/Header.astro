---
/**
 * サイトヘッダー（ZENSHIN Tech）
 *
 * zenshin-hp と地続きの意匠（ダーク地 + 白ナビ）。
 * ロックアップは「ZENSHIN ロゴ + TECH 金チップ」（ロゴは h-7 を維持し、チップは垂直センター揃え）。
 * コンテンツ種別のナビ（ブログ/スライド）は持たず、会社サイトへのリンクのみ
 * （検索・絞り込みはトップページの一覧に統合されている）。
 */
import { Icon } from "astro-icon/components";
import { ROUTES } from "@/consts/routes";
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-surface-dark">
  <div class="mx-auto max-w-6xl px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">
      <!-- ロックアップ: ロゴ + TECH 金チップ（垂直センター揃え） -->
      <a href={ROUTES.home} class="relative z-50 flex items-center gap-2.5 active:opacity-70 active:scale-95">
        <img
          src="/assets/brand/ZENSHIN-logo-white.webp"
          alt="ZENSHIN"
          width="140"
          height="32"
          class="h-7 w-auto"
          loading="eager"
          fetchpriority="high"
        />
        {/* ZENSHIN サブブランドバッジ（完全な四角・Michroma・金グラデ × 白抜き） */}
        <span
          class="rounded-none bg-[linear-gradient(135deg,#e4d4a8,#c4a97d_55%,#8c6f42)] px-[10px] py-[7px] font-[Michroma] text-[12px] font-normal uppercase leading-none tracking-[0.18em] text-white"
        >
          Tech
        </span>
      </a>

      <!-- 右側: ホームページ（コーポレートサイト）のみ（検索はトップページの一覧に統合） -->
      <a
        href={ROUTES.corporate}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm font-medium text-on-surface-dark/90 transition-all duration-200 hover:text-white active:opacity-70 active:scale-95"
      >
        <span>ホームページ</span>
        <Icon name="heroicons:arrow-top-right-on-square-20-solid" class="h-3.5 w-3.5 opacity-60" aria-hidden="true" />
      </a>
    </div>
  </div>
</header>
