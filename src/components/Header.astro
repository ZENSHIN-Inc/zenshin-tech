---
/**
 * サイトヘッダー（ZENSHIN Tech）
 *
 * zenshin-hp の Header から移植。HP はヒーロー上で透明 → スクロールで白背景に
 * 切り替えるが、本サイトは全ページ共通の常時ダークヘッダーに単純化している
 * （ロゴ・ナビ色の切り替えスクリプトなし）。
 */
import { Icon } from "astro-icon/components";
import { ROUTES } from "@/consts/routes";

const navItems = [
  { label: "ブログ", href: ROUTES.blog, external: false },
  { label: "スライド", href: ROUTES.slides, external: false },
  { label: "会社サイト", href: ROUTES.corporate, external: true },
];

const currentPath = Astro.url.pathname;

const isActiveNavItem = (href: string) =>
  href !== ROUTES.corporate && currentPath.startsWith(href);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-surface-dark/95 backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">
      <!-- ロゴ + メディア名 -->
      <a href={ROUTES.home} class="relative z-50 flex items-baseline gap-2 active:opacity-70 active:scale-95">
        <img
          src="/assets/brand/ZENSHIN-logo-white.webp"
          alt="ZENSHIN"
          width="140"
          height="32"
          class="h-7 w-auto"
          loading="eager"
          fetchpriority="high"
        />
        <span class="font-display text-lg font-bold tracking-wide text-label">Tech</span>
      </a>

      <!-- デスクトップナビ -->
      <nav class="hidden items-center gap-6 md:flex">
        {navItems.map((item) => {
          const isActive = isActiveNavItem(item.href);
          return (
            <a
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noopener noreferrer" : undefined}
              class="inline-flex items-center gap-1 text-sm font-medium text-on-surface-dark/90 transition-all duration-200 hover:text-white active:opacity-70 active:scale-95"
              {...(isActive ? { "aria-current": "page" } : {})}
            >
              <span>{item.label}</span>
              {item.external && (
                <Icon name="heroicons:arrow-top-right-on-square-20-solid" class="h-3.5 w-3.5 opacity-60" aria-hidden="true" />
              )}
            </a>
          );
        })}
      </nav>

      <!-- モバイル: メニューボタン -->
      <div class="flex items-center gap-2 md:hidden">
        <button
          id="menu-toggle"
          class="relative z-50 flex h-12 w-12 items-center justify-center active:opacity-70 active:scale-90"
          aria-label="メニュー"
          aria-expanded="false"
        >
          {/* ハンバーガーアイコン（3本線） */}
          <svg id="menu-icon-open" class="h-6 w-6 text-white transition-all duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          {/* 閉じるアイコン（×） */}
          <svg id="menu-icon-close" class="h-6 w-6 text-white opacity-0 absolute transition-all duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- モバイルメニュー（header の外に配置し、fixed 位置を確実にする） -->
<div id="mobile-menu" class="pointer-events-none fixed inset-0 z-40 bg-surface-dark opacity-0 transition-opacity duration-300">
  <div class="flex h-full flex-col items-center justify-center gap-8">
    {navItems.map((item, i) => {
      const isActive = isActiveNavItem(item.href);
      return (
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noopener noreferrer" : undefined}
          class="mobile-link flex w-72 max-w-[calc(100vw-3rem)] translate-y-4 items-center justify-center text-center text-xl font-medium text-on-surface-dark opacity-0 transition-all duration-500 hover:text-accent active:opacity-70 active:scale-95"
          style={`transition-delay: ${120 + i * 50}ms`}
          {...(isActive ? { "aria-current": "page" } : {})}
        >
          <span class="inline-flex items-center gap-1.5">
            {item.label}
            {item.external && (
              <Icon name="heroicons:arrow-top-right-on-square-20-solid" class="h-4 w-4 opacity-60" aria-hidden="true" />
            )}
          </span>
        </a>
      );
    })}
  </div>
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");
  let open = false;

  // メニュー開閉
  toggle?.addEventListener("click", () => {
    open = !open;
    toggle.setAttribute("aria-expanded", String(open));
    if (open) {
      menu?.classList.remove("pointer-events-none", "opacity-0");
      menu?.classList.add("pointer-events-auto", "opacity-100");
      iconOpen?.classList.add("opacity-0");
      iconClose?.classList.remove("opacity-0");
      menu?.querySelectorAll(".mobile-link").forEach((l) => l.classList.remove("opacity-0", "translate-y-4"));
      document.body.style.overflow = "hidden";
      // メニュー展開時はメインコンテンツを不活性化（a11y）
      document.querySelector("main")?.setAttribute("inert", "");
    } else {
      menu?.classList.add("pointer-events-none", "opacity-0");
      menu?.classList.remove("pointer-events-auto", "opacity-100");
      iconOpen?.classList.remove("opacity-0");
      iconClose?.classList.add("opacity-0");
      menu?.querySelectorAll(".mobile-link").forEach((l) => l.classList.add("opacity-0", "translate-y-4"));
      document.body.style.overflow = "";
      document.querySelector("main")?.removeAttribute("inert");
    }
  });

  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => { if (open) toggle?.click(); })
  );
</script>
