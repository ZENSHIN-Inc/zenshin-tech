---
/**
 * フッター（ZENSHIN 技術ブログ）— ダーク背景、ロゴ + サイトマップ + コピーライト
 * （zenshin-hp のフッターと同じ構成: ロゴ + 説明 + 住所 / カテゴリ別リンク / コピーライト）
 */
import { Icon } from "astro-icon/components";
import { ROUTES } from "@/consts/routes";

// トップの種別チップと重複するため「ブログ / スライド」の個別リンクは置かない。
// 「運営会社への導線」と「フォロー導線」で目的別に分ける
const linkGroups = [
  {
    heading: "運営会社",
    links: [
      { label: "ホームページ", href: ROUTES.corporate, external: false },
      { label: "お問い合わせ", href: ROUTES.corporateContact, external: false },
    ],
  },
  {
    heading: "フォローする",
    links: [
      { label: "X (@zenshin_inc)", href: "https://x.com/zenshin_inc", external: true },
      { label: "RSS", href: ROUTES.rss, external: false },
    ],
  },
];
---

<footer class="bg-surface-dark">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div class="grid grid-cols-2 gap-x-6 gap-y-8 md:grid-cols-[1.5fr_1fr_1fr] md:gap-8">
      <!-- ロゴ + 説明 -->
      <div class="order-last col-span-2 max-w-xs md:order-none md:col-span-1">
        <a href={ROUTES.home} class="inline-flex items-end gap-2 active:opacity-70 active:scale-95">
          <img src="/assets/brand/ZENSHIN-logo-white.webp" alt="ZENSHIN 技術ブログ - ホームに戻る" width="120" height="28" class="h-6 w-auto" loading="lazy" />
          {/* 高さと縦位置はロゴの文字（N）に一致させる（h-6=24px 表示 → 文字高 19px・下端オフセット 1px） */}
          <span class="mb-px inline-flex h-[19px] items-center rounded-none bg-[linear-gradient(135deg,#c4a97d,#7a5f37_45%,#4a3a20)] px-2 text-[10px] font-bold leading-none tracking-[0.02em] text-white">技術ブログ</span>
        </a>
        {/* 説明文 — 文節単位の inline-block で「スライド資料」等の語中改行を防ぐ */}
        <p class="mt-4 text-sm leading-relaxed text-white/80">
          株式会社ZENSHINの技術ブログ<br /><span class="inline-block">AI活用や</span><span class="inline-block">プロダクト開発の</span><span class="inline-block">技術知見を</span><span class="inline-block">記事や</span><span class="inline-block">スライド資料で</span><span class="inline-block">発信しています</span>
        </p>
        <address class="mt-3 text-xs not-italic leading-relaxed text-white/60">
          〒150-0041<br />
          東京都渋谷区神南1-11-4<br />
          FPGリンクス神南 5F
        </address>
      </div>

      <!-- カテゴリ別リンク -->
      {linkGroups.map((group) => (
        <nav aria-label={group.heading}>
          <p class="text-xs font-bold tracking-wider text-white/45">{group.heading}</p>
          <ul class="mt-3 space-y-2.5 md:mt-4 md:space-y-3">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="text-sm text-white/80 transition-colors hover:text-white active:opacity-70 active:scale-95"
                >
                  {link.label}
                  {link.external && (
                    <Icon name="heroicons:arrow-top-right-on-square-20-solid" class="ml-0.5 inline h-3 w-3 align-[-1px] opacity-60" aria-hidden="true" />
                  )}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>
  </div>

  <!-- コピーライト -->
  <div class="border-t border-white/5 py-6">
    <p class="text-center text-sm text-white/80">
      &copy; {new Date().getFullYear()} 株式会社ZENSHIN. All rights reserved.
    </p>
  </div>
</footer>
