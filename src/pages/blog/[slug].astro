---
/**
 * ブログ詳細ページ
 * マークダウン記事を個別表示
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BreadcrumbJsonLd from "@/components/BreadcrumbJsonLd.astro";
import BlogSidebar from "@/components/BlogSidebar.astro";
import AuthorCard from "@/components/AuthorCard.astro";
import ShareButtons from "@/components/ShareButtons.astro";
import RelatedPosts from "@/components/RelatedPosts.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { Icon } from "astro-icon/components";
import { getCollection, getEntry, render } from "astro:content";
import { ROUTES } from "@/consts/routes";
import { filterPublished } from "@/lib/drafts";

export async function getStaticPaths() {
  const allPosts = filterPublished(await getCollection("blog"));
  return allPosts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((h) => h.depth <= 3);
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "";
const articleUrl = `${siteUrl}${ROUTES.blogPost(post.data.slug)}`;
const author = await getEntry("authors", post.data.author.id);
const authorName = author?.data.name;

/** 日付を YYYY.MM.DD 形式にフォーマット */
function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}.${m}.${d}`;
}

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  url: `${siteUrl}${ROUTES.blogPost(post.data.slug)}`,
  image: `${siteUrl}${ROUTES.ogImageBlog(post.data.slug)}`,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: { "@type": "Person", name: authorName ?? "株式会社ZENSHIN" },
  publisher: {
    "@type": "Organization",
    name: "株式会社ZENSHIN",
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/assets/brand/ZENSHIN-icon-square.webp`,
    },
  },
});
---

<BaseLayout
  title={`${post.data.title} | ZENSHIN Tech`}
  description={post.data.description}
  ogType="article"
  ogImage={ROUTES.ogImageBlog(post.data.slug)}
>
  <BreadcrumbJsonLd items={[
    { name: "ホーム", path: ROUTES.home },
    { name: "ブログ", path: ROUTES.blog },
    { name: post.data.title, path: ROUTES.blogPost(post.data.slug) },
  ]} />
  <script is:inline type="application/ld+json" set:html={articleJsonLd} />
  <Header />

  <!-- ページタイトル帯 — パンくず + 日付 + タイトル（タグは記事本文の上に移動） -->
  <section class="bg-surface-dark pt-28 pb-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 xl:px-20">
      <Breadcrumbs
        items={[
          { name: "ホーム", path: ROUTES.home },
          { name: "ブログ", path: ROUTES.blog },
          { name: post.data.title },
        ]}
        class="mb-4"
      />
      <div class="flex flex-wrap items-center gap-3">
        <time datetime={post.data.date.toISOString()} class="text-sm text-on-surface-dark/75">
          {formatDate(post.data.date)}
        </time>
        {!post.data.published && (
          <span
            class="inline-flex items-center rounded-sm bg-warning px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-surface-dark"
            aria-label="下書き記事"
          >
            Draft
          </span>
        )}
      </div>
      <h1 class="mt-3 whitespace-pre-line text-2xl font-bold leading-snug text-on-surface-dark md:text-3xl lg:text-[2rem] lg:leading-snug">
        {post.data.title}
      </h1>
    </div>
  </section>

  <!-- 記事全体のラッパー — Zenn風のグレー背景 -->
  <div class="blog-page-bg flex-1 py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 xl:px-20">
      <div class="lg:flex lg:gap-6">

        {/* メインコンテンツ — 白カード。
            xl 以上では記事カードの左外にシェアバーを絶対配置で overlay し、
            記事カードの幅は一切狭めない（xl 未満は container 左余白が足りないため非表示） */}
        <article class="relative min-w-0 flex-1 p-2">
          {/* 左外側シェアバー（xl+）— xl 未満は display:none なので SR もフォーカスも
              到達せず、下部のカード内シェアと重複読み上げは発生しない。
              pointer-events-none は sticky 子要素以外がクリックを吸わないための視覚レイヤ制御 */}
          <div
            class="pointer-events-none absolute inset-y-2 -left-14 hidden w-12 xl:block"
          >
            <div class="pointer-events-auto sticky top-24">
              <ShareButtons
                url={articleUrl}
                title={post.data.title}
                authorName={authorName}
                orientation="vertical"
              />
            </div>
          </div>

          <div class="blog-card rounded-2xl px-6 py-10 sm:px-10">
            {/* 本文の上にタグ（サイドバーと同一スタイル） */}
            <ul class="mb-8 flex flex-wrap gap-1.5">
              {post.data.tags.map((tag) => (
                <li>
                  <a
                    href={ROUTES.tag(tag)}
                    class="inline-flex items-center gap-0.5 rounded-sm bg-label/10 px-2 py-0.5 text-xs font-bold text-label transition-colors hover:bg-label/20 active:scale-95 active:opacity-80"
                  >
                    <Icon name="heroicons:hashtag-20-solid" class="h-3 w-3 opacity-70" />{tag}
                  </a>
                </li>
              ))}
            </ul>

            <div class="blog-prose markdown-body">
              <Content />
            </div>

            {/* 著者 + シェア（xl 未満では記事末尾にシェアを表示、xl 以上は左 sticky に任せる）
                モバイル含めて常に 1 行（著者 左 / シェア 右）で配置する */}
            <div class="mt-12 border-t border-border pt-8">
              <div class="flex items-center justify-between gap-4">
                <AuthorCard authorId={post.data.author.id} class="min-w-0" />
                <div class="shrink-0 xl:hidden">
                  <ShareButtons
                    url={articleUrl}
                    title={post.data.title}
                    authorName={authorName}
                  />
                </div>
              </div>
            </div>

            {/* 一覧に戻る */}
            <div class="mt-8 border-t border-border pt-8">
              <a href={ROUTES.blog} class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent-hover transition-all active:opacity-70 active:scale-95">
                <Icon name="heroicons:arrow-left-20-solid" class="h-4 w-4" />
                ブログ一覧に戻る
              </a>
            </div>
          </div>

          {/* 関連記事（同タグの最新記事） */}
          <RelatedPosts
            currentSlug={post.data.slug}
            tags={post.data.tags}
            class="mt-10"
          />

          {/* タグ + 月別アーカイブ（縦積み。コンテンツ量で自然に伸びる） */}
          <BlogSidebar class="mt-10" />
        </article>

        {/* サイドバー目次 — 記事とは独立した回遊導線はカード下にあるので、ここは目次のみ */}
        {tocHeadings.length > 0 && (
          <aside class="hidden w-64 shrink-0 p-2 lg:block">
            <div class="sticky top-24">
              <nav id="toc-nav" class="blog-card rounded-2xl px-5 py-5 max-h-[calc(100vh-7rem)] overflow-y-auto" aria-label="目次">
                <a href="#" class="mb-4 block text-base font-bold text-primary hover:text-accent transition-colors">目次</a>
                <ol class="toc-list">
                  {tocHeadings.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        data-toc-link={h.slug}
                        class={`toc-link ${h.depth === 3 ? "toc-link--h3" : "toc-link--h2"}`}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            </div>
          </aside>
        )}
      </div>
    </div>
  </div>

  <Footer />

  {/* コードブロックのコピー ボタン用アイコン — astro-icon でビルド時に SVG を展開し、
      クライアント側 JS は <template>.innerHTML で取り回す。手書き SVG を埋め込まず
      他コンポーネント（ShareButtons 等）と heroicons の見た目を統一する */}
  <template id="code-copy-icon-tpl"><Icon name="heroicons:document-duplicate" aria-hidden="true" /></template>
  <template id="code-check-icon-tpl"><Icon name="heroicons:check" aria-hidden="true" /></template>

  <script>
    // 見出しクリックでアンカーリンク（GitHub風）
    document.querySelectorAll(".blog-prose h2[id], .blog-prose h3[id]").forEach((heading) => {
      heading.addEventListener("click", () => {
        const url = `${window.location.pathname}#${heading.id}`;
        history.replaceState(null, "", url);
        navigator.clipboard?.writeText(window.location.href);
      });
    });

    // コードブロックにコピー ボタンを追加
    const copyIcon =
      document.querySelector<HTMLTemplateElement>("#code-copy-icon-tpl")?.innerHTML ?? "";
    const checkIcon =
      document.querySelector<HTMLTemplateElement>("#code-check-icon-tpl")?.innerHTML ?? "";

    document.querySelectorAll<HTMLPreElement>(".blog-prose pre").forEach((pre) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "code-copy-btn";
      btn.innerHTML = copyIcon;
      btn.setAttribute("aria-label", "コードをコピー");

      // fade-out 完了後にアイコンをコピー状態へ戻す（一瞬元アイコンが見える問題の回避）
      btn.addEventListener("transitionend", (e) => {
        if (e.propertyName !== "opacity") return;
        if (btn.classList.contains("is-copied")) return;
        if (getComputedStyle(btn).opacity !== "0") return;
        btn.innerHTML = copyIcon;
      });

      let resetTimerId: ReturnType<typeof setTimeout> | null = null;

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code")?.textContent ?? pre.textContent ?? "";
        try {
          await navigator.clipboard.writeText(code);
          btn.innerHTML = checkIcon;
          btn.classList.add("is-copied");
          btn.setAttribute("aria-label", "コピーしました");
          if (resetTimerId !== null) clearTimeout(resetTimerId);
          resetTimerId = setTimeout(() => {
            btn.classList.remove("is-copied");
            btn.setAttribute("aria-label", "コードをコピー");
            // ホバー中でまだ表示されている場合はそのままチェックを残す。
            // マウスが外れて opacity が 0 になったら transitionend でコピー アイコンに戻す。
          }, 1500);
        } catch {
          /* clipboard 権限が取れない環境では何もしない */
        }
      });
      pre.appendChild(btn);
    });

    // 目次のアクティブ状態を IntersectionObserver で切り替え
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
    if (tocLinks.length > 0) {
      const headingIds = Array.from(tocLinks).map((a) => a.dataset.tocLink!);
      const headings = headingIds
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      let activeId = headingIds[0];
      // クリック直後はスクロール中に Observer が別セクションを拾ってしまい
      // active が飛ぶので、一定時間 Observer の更新を抑制する
      let suppressObserverUntil = 0;

      const observer = new IntersectionObserver(
        (entries) => {
          if (Date.now() < suppressObserverUntil) return;

          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible.length > 0) {
            activeId = visible[0].target.id;
          }

          for (const link of tocLinks) {
            const isActive = link.dataset.tocLink === activeId;
            link.classList.toggle("is-active", isActive);
          }
        },
        { rootMargin: "-96px 0px -60% 0px", threshold: 0 }
      );

      for (const h of headings) observer.observe(h);

      // タップ時に即座にアクティブを切り替え、スクロール完了までは Observer を抑制
      for (const link of tocLinks) {
        link.addEventListener("click", () => {
          activeId = link.dataset.tocLink!;
          for (const other of tocLinks) {
            other.classList.toggle("is-active", other === link);
          }
          suppressObserverUntil = Date.now() + 800;
        });
      }
    }
  </script>
</BaseLayout>
