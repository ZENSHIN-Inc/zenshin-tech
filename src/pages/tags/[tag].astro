---
/**
 * タグ別一覧ページ（ブログ記事 + スライド共通）
 *
 * `/tags/[tag]/` の URL で、タグに紐づくコンテンツを一覧表示する。
 * ビルド時に `getStaticPaths` で全タグ分の静的ページを生成する。
 */
import PageLayout from "@/layouts/PageLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import BlogSidebar from "@/components/BlogSidebar.astro";
import { ROUTES } from "@/consts/routes";
import { loadContentItems } from "@/lib/content-items";

export async function getStaticPaths() {
  const allItems = await loadContentItems();
  const tagSet = new Set<string>();
  for (const item of allItems) {
    for (const tag of item.tags) tagSet.add(tag);
  }
  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      items: allItems.filter((i) => i.tags.includes(tag)),
    },
  }));
}

const { tag, items } = Astro.props;
---

<PageLayout
  title={`#${tag} のコンテンツ | ZENSHIN Tech`}
  description={`${tag} タグが付いた記事・スライドの一覧。株式会社ZENSHINの技術メディア ZENSHIN Tech。`}
  pageTitle={`#${tag}`}
  headerMaxWidth="max-w-6xl"
  breadcrumbs={[
    { name: "ホーム", path: ROUTES.home },
    { name: `#${tag}`, path: ROUTES.tag(tag) },
  ]}
>
  {/* ヘッダー帯の h1 直下に件数を小さく表示 */}
  <p slot="pageMeta" class="mt-3 text-sm text-on-surface-dark/75">
    <span class="font-bold tabular-nums text-on-surface-dark">{items.length}</span> 件のコンテンツ
  </p>

  <section class="bg-surface section-padding">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div
        class="lg:grid lg:grid-cols-[minmax(0,1fr)_240px] lg:gap-10 xl:grid-cols-[minmax(0,1fr)_260px]"
      >
        <div class="min-w-0">
          {
            items.length > 0 ? (
              <ul class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2">
                {items.map((item, i) => (
                  <ArticleCard
                    href={item.href}
                    ogImageSrc={item.ogImageSrc}
                    title={item.title}
                    tags={item.tags}
                    date={item.date}
                    contentType={item.contentType}
                    external={item.external}
                    pdfHref={item.pdfHref}
                    linkable
                    delay={String(Math.min(i + 1, 5))}
                    isDraft={item.isDraft}
                  />
                ))}
              </ul>
            ) : (
              <div class="text-center">
                <p class="text-lg text-muted">該当するコンテンツがありません。</p>
              </div>
            )
          }
        </div>

        <aside class="mt-12 lg:mt-0" aria-label="コンテンツナビゲーション">
          <BlogSidebar currentTag={tag} class="lg:sticky lg:top-24" />
        </aside>
      </div>
    </div>
  </section>
</PageLayout>
