---
/**
 * スライド一覧ページ
 * 単一種別の一覧なのでタイプバッジは付けない（トップの混在一覧のみ表示）
 */
import PageLayout from "@/layouts/PageLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getCollection } from "astro:content";

const slides = (await getCollection("slides")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<PageLayout
  title="スライド | ZENSHIN Tech"
  description="株式会社ZENSHINの公開スライド。勉強会・社内共有で使った資料を HTML / PDF で公開しています。"
  pageTitle="スライド"
  headerMaxWidth="max-w-6xl"
>
  <section class="bg-surface section-padding">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      {
        slides.length > 0 ? (
          <ul class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
            {slides.map((slide, i) => (
              <ArticleCard
                href={slide.data.urls.page}
                ogImageSrc={slide.data.urls.ogImage}
                title={slide.data.title}
                tags={slide.data.tags}
                date={slide.data.date}
                external
                pdfHref={slide.data.urls.pdf}
                linkable
                delay={String(Math.min(i + 1, 5))}
              />
            ))}
          </ul>
        ) : (
          <div class="text-center">
            <p class="text-lg text-muted">スライドはまだありません。</p>
          </div>
        )
      }
    </div>
  </section>
</PageLayout>
